<Window x:Class="IcarusDroneService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="iCARUS Drone Service System"
        Height="700"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid Background="#E0E0E0">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#B3D9FF"
                BorderBrush="Gray"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="40"
                         Height="40"
                         Margin="15,0,10,0"
                         Fill="LightBlue"
                         Stroke="SteelBlue"
                         StrokeThickness="2"/>
                <TextBlock Text="ICARUS DRONE SERVICE SYSTEM"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="22"
                           Foreground="#222"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Input Panel -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="5"
                    Margin="0,0,10,0"
                    Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="SERVICE PANEL"
                                   Background="#40E0D0"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   TextAlignment="Center"
                                   Padding="8"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Service Tag" Margin="5,5,5,0" FontWeight="SemiBold"/>
                        <xctk:IntegerUpDown x:Name="numServiceTag"
                                            Minimum="100"
                                            Maximum="900"
                                            Increment="10"
                                            Value="100"
                                            Margin="5"
                                            Height="28"/>

                        <TextBlock Text="Client Name" Margin="5,8,5,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtClientName"
                                 Margin="5"
                                 Height="28"/>

                        <TextBlock Text="Drone Model" Margin="5,8,5,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtDroneModel"
                                 Margin="5"
                                 Height="28"/>

                        <TextBlock Text="Service Problem" Margin="5,8,5,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtProblem"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="5"/>

                        <TextBlock Text="Service Cost" Margin="5,8,5,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtCost"
                                 Margin="5"
                                 Height="28"
                                 PreviewTextInput="txtCost_PreviewTextInput"/>

                        <TextBlock Text="Service Priority" Margin="5,10,5,0" FontWeight="SemiBold"/>
                        <StackPanel Margin="5,5,5,0">
                            <RadioButton x:Name="radRegular"
                                         Content="REGULAR SERVICE"
                                         GroupName="Priority"
                                         IsChecked="True"
                                         Margin="0,0,0,5"/>
                            <RadioButton x:Name="radExpress"
                                         Content="EXPRESS SERVICE"
                                         GroupName="Priority"/>
                        </StackPanel>

                        <Button x:Name="btnAddItem"
                                Content="Add New Item"
                                Click="AddNewItem_Click"
                                Margin="5,20,5,5"
                                Height="40"
                                Background="#333"
                                Foreground="White"
                                FontWeight="Bold"/>

                        <Button x:Name="btnProcessRegular"
                                Content="Process Regular"
                                Click="btnProcessRegular_Click"
                                Margin="5,10,5,5"
                                Height="38"
                                Background="#247BA0"
                                Foreground="White"
                                FontWeight="Bold"/>

                        <Button x:Name="btnProcessExpress"
                                Content="Process Express"
                                Click="btnProcessExpress_Click"
                                Margin="5"
                                Height="38"
                                Background="#D1495B"
                                Foreground="White"
                                FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Display Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- Queue Lists -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Regular Queue -->
                    <GroupBox Grid.Column="0"
                              Header="Regular Service Queue"
                              Margin="0,0,0,5"
                              FontWeight="Bold">
                        <ListView x:Name="lvRegular"
                                  Margin="5"
                                  MouseLeftButtonUp="lvRegular_MouseClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Client Name"
                                                    Width="120"
                                                    DisplayMemberBinding="{Binding ClientName}"/>
                                    <GridViewColumn Header="Drone Model"
                                                    Width="120"
                                                    DisplayMemberBinding="{Binding DroneModel}"/>
                                    <GridViewColumn Header="Service Tag"
                                                    Width="85"
                                                    DisplayMemberBinding="{Binding ServiceTag}"/>
                                    <GridViewColumn Header="Service Problem"
                                                    Width="220"
                                                    DisplayMemberBinding="{Binding ServiceProblem}"/>
                                    <GridViewColumn Header="Service Cost"
                                                    Width="90"
                                                    DisplayMemberBinding="{Binding ServiceCost}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                    <!-- Express Queue -->
                    <GroupBox Grid.Column="2"
                              Header="Express Service Queue"
                              Margin="0,0,0,5"
                              FontWeight="Bold">
                        <ListView x:Name="lvExpress"
                                  Margin="5"
                                  MouseLeftButtonUp="lvExpress_MouseClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Client Name"
                                                    Width="120"
                                                    DisplayMemberBinding="{Binding ClientName}"/>
                                    <GridViewColumn Header="Drone Model"
                                                    Width="120"
                                                    DisplayMemberBinding="{Binding DroneModel}"/>
                                    <GridViewColumn Header="Service Tag"
                                                    Width="85"
                                                    DisplayMemberBinding="{Binding ServiceTag}"/>
                                    <GridViewColumn Header="Service Problem"
                                                    Width="220"
                                                    DisplayMemberBinding="{Binding ServiceProblem}"/>
                                    <GridViewColumn Header="Service Cost"
                                                    Width="90"
                                                    DisplayMemberBinding="{Binding ServiceCost}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>
                </Grid>

                <!-- Completed Service List -->
                <GroupBox Grid.Row="1"
                          Header="Completed Service List"
                          Margin="0,10,0,0"
                          FontWeight="Bold">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="lbCompleted"
                                 Grid.Row="0"
                                 MouseDoubleClick="lbCompleted_MouseDoubleClick"/>

                        <TextBlock Grid.Row="1"
                                   Text="Double-click an item to remove it from the finished list."
                                   Margin="5,8,5,0"
                                   FontStyle="Italic"
                                   Foreground="Gray"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="Red">
            <TextBlock x:Name="txtStatusBar"
                       Text="STATUS BAR"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>